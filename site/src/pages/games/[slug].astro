---
import { existsSync, readdirSync } from "node:fs";
import path from "node:path";
import Layout from "../../layouts/Layout.astro";
import PdfDeckViewer from "../../components/PdfDeckViewer.astro";
import { games, type GameEntry } from "../../data/games";
import { showcaseAssets } from "../../data/showcaseAssets";
import { withBase } from "../../utils/paths";

export function getStaticPaths() {
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props as { game: GameEntry };
const asset = showcaseAssets[game.slug] ?? { sourceFiles: [] };
const isPlayable = Boolean(asset.playUrl);
const visibleLinks = game.links.filter((link) => {
  const href = link.href.toLowerCase();
  return !href.endsWith(".zip") && !href.endsWith(".pptx");
});

const tagClass = (tag: string) => {
  if (tag.includes("Winner") || tag.includes("Runner")) return "rank";
  if (tag === "Pygame" || tag === "Unity") return "track";
  return "special";
};

const getSlideImages = (slidePdf?: string) => {
  if (!slidePdf) return [];
  const pdfPublicPath = path.join(process.cwd(), "public", slidePdf.replace(/^\//, ""));
  const slideDir = path.dirname(pdfPublicPath);
  if (!existsSync(slideDir)) return [];
  return readdirSync(slideDir)
    .filter((file) => /^slide-\d+\.(png|jpe?g)$/i.test(file))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
    .map((file) => `${path.posix.dirname(slidePdf)}/${file}`);
};

const slideImages = getSlideImages(asset.slidePdf);

const keyboardRows =
  asset.keyboardMode === "full"
    ? [
        ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"],
        ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"],
        ["A", "S", "D", "F", "G", "H", "J", "K", "L"],
        ["Z", "X", "C", "V", "B", "N", "M"],
        ["ArrowLeft", "ArrowDown", "ArrowUp", "ArrowRight"],
        ["Backspace", "Space", "Enter"],
      ]
    : asset.keyboardMode === "wasd"
      ? [["W"], ["A", "S", "D"], ["Space", "Enter"]]
      : [];

const keyLabel = (key: string) =>
  ({
    ArrowLeft: "Left",
    ArrowDown: "Down",
    ArrowUp: "Up",
    ArrowRight: "Right",
    Backspace: "Bksp",
    Space: "Space",
    Enter: "Enter",
  })[key] ?? key;
---

<Layout title={game.title} description={game.summary}>
  <main class="container">
    <section class="section-block compact">
      <a class="button" href={withBase("/")}>Back to showcase</a>
    </section>

    <section class="detail-hero">
      <div class="detail-media">
        <img src={withBase(game.cover)} alt="" />
      </div>
      <div class="detail-copy">
        <div class="tag-row">
          <span class={`tag ${tagClass(game.track)}`}>{game.track}</span>
          {game.awards.map((award) => <span class={`tag ${tagClass(award)}`}>{award}</span>)}
          <span class={`tag play-state ${isPlayable ? "playable" : "pending"}`}>
            {isPlayable ? "Playable" : "Export pending"}
          </span>
        </div>
        <p class="eyebrow">{game.teamCode} - {game.track}</p>
        <h1>{game.title}</h1>
        <p class="team">{game.team}</p>
      </div>
    </section>

    <section class:list={["detail-body", isPlayable && "detail-body-playable"]}>
      <article class="writeup">
        {game.writeup.split(/\n\s*\n/).map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <aside class="side-panel">
        <section class="play-panel">
          <div class="panel-heading-row">
            <p class="eyebrow">Play</p>
            <span class={`tag play-state ${isPlayable ? "playable" : "pending"}`}>
              {isPlayable ? "Playable now" : "Export pending"}
            </span>
          </div>

          {
            isPlayable ? (
              <>
                <iframe
                  class="play-embed"
                  data-play-embed
                  src={withBase(asset.playUrl!)}
                  title={`${game.title} playable build`}
                  loading="lazy"
                  allow="autoplay; fullscreen; gamepad"
                  sandbox="allow-scripts allow-same-origin allow-pointer-lock allow-popups allow-forms"
                />
                {keyboardRows.length > 0 && (
                  <div
                    class={`game-keyboard ${asset.keyboardMode === "full" ? "full-keyboard" : "wasd-keyboard"}`}
                    data-game-keyboard
                  >
                    <button class="focus-game" type="button" data-focus-game>
                      Focus game
                    </button>
                    <div class="key-row-stack">
                      {keyboardRows.map((row) => (
                        <div class="key-row">
                          {row.map((key) => (
                            <button class={`key-button key-${key.toLowerCase()}`} type="button" data-key={key}>
                              {keyLabel(key)}
                            </button>
                          ))}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="play-frame">
                <div>
                  <p class="play-title">Export pending</p>
                  <p class="play-note">{game.playNote}</p>
                </div>
              </div>
            )
          }
        </section>

        {
          visibleLinks.length > 0 && (
            <section class="links-panel">
              <p class="eyebrow">Files</p>
              <h3>Slides and documents</h3>
              <div class="link-list">
                {visibleLinks.map((link) => (
                  <a class="mini-link" href={encodeURI(withBase(link.href))}>
                    {link.label}
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </aside>
    </section>

    <section class="showcase-section">
      <div class="section-heading">
        <p class="eyebrow">Slides</p>
        <h2>Presentation deck</h2>
      </div>

      {
        asset.slidePdf ? (
          <PdfDeckViewer src={asset.slidePdf} title={`${game.title} presentation`} slideImages={slideImages} />
        ) : (
          <div class="empty-panel">
            <h3>PDF preview pending</h3>
            <p>This entry does not have a PDF export in the archive yet.</p>
          </div>
        )
      }
    </section>

    <section class="showcase-section">
      <div class="section-heading">
        <p class="eyebrow">Source</p>
        <h2>Full source</h2>
      </div>

      {
        asset.sourceFiles.length > 0 ? (
          <div class="code-grid">
            {asset.sourceFiles.map((file) => (
              <details class="code-panel" data-source-card data-source-url={encodeURI(withBase(file.href))}>
                <summary>
                  <div>
                    <p class="eyebrow">{file.language === "python" ? "Pygame" : "Unity C#"}</p>
                    <h3>{file.label}</h3>
                  </div>
                  <span>Toggle source</span>
                </summary>
                <div class="source-link-row">
                  <a href={encodeURI(withBase(file.href))}>Open raw source</a>
                </div>
                <pre><code data-source-code>Open this card to load source.</code></pre>
              </details>
            ))}
          </div>
        ) : (
          <div class="empty-panel">
            <h3>Source preview pending</h3>
            <p>No readable source file has been matched to this entry yet.</p>
          </div>
        )
      }
    </section>
  </main>
</Layout>

<script>
  // @ts-nocheck
  const keyMeta = {
    ArrowLeft: { key: "ArrowLeft", code: "ArrowLeft", keyCode: 37 },
    ArrowUp: { key: "ArrowUp", code: "ArrowUp", keyCode: 38 },
    ArrowRight: { key: "ArrowRight", code: "ArrowRight", keyCode: 39 },
    ArrowDown: { key: "ArrowDown", code: "ArrowDown", keyCode: 40 },
    Backspace: { key: "Backspace", code: "Backspace", keyCode: 8 },
    Enter: { key: "Enter", code: "Enter", keyCode: 13 },
    Space: { key: " ", code: "Space", keyCode: 32 },
  };

  const getKeyMeta = (value) => {
    if (keyMeta[value]) return keyMeta[value];
    const upper = value.toUpperCase();
    return {
      key: value.length === 1 ? value.toLowerCase() : value,
      code: value.length === 1 && /[A-Z]/.test(upper) ? `Key${upper}` : value,
      keyCode: value.length === 1 ? upper.charCodeAt(0) : 0,
    };
  };

  const fireGameKey = (iframe, value, type) => {
    const targetWindow = iframe?.contentWindow;
    if (!targetWindow) return;
    const meta = getKeyMeta(value);
    const eventInit = {
      key: meta.key,
      code: meta.code,
      keyCode: meta.keyCode,
      which: meta.keyCode,
      bubbles: true,
      cancelable: true,
    };
    targetWindow.focus();
    targetWindow.dispatchEvent(new KeyboardEvent(type, eventInit));
    targetWindow.document?.dispatchEvent(new KeyboardEvent(type, eventInit));
  };

  // Only show the on-screen keyboard on touch devices that have no physical
  // keyboard (phones/tablets). On desktop the user has a real keyboard, so the
  // on-screen keys are redundant clutter — hide them and let the game take key
  // input directly once it's clicked/focused.
  const isTouchDevice =
    window.matchMedia("(hover: none) and (pointer: coarse)").matches ||
    /Android|iPhone|iPod/i.test(navigator.userAgent);

  document.querySelectorAll("[data-game-keyboard]").forEach((keyboard) => {
    if (!isTouchDevice) {
      keyboard.style.display = "none";
      return;
    }

    const playPanel = keyboard.closest(".play-panel");
    const iframe = playPanel?.querySelector("[data-play-embed]");

    keyboard.querySelector("[data-focus-game]")?.addEventListener("click", () => {
      iframe?.focus();
      iframe?.contentWindow?.focus();
    });

    keyboard.querySelectorAll("[data-key]").forEach((button) => {
      const key = button.dataset.key;
      if (!key) return;

      const press = (event) => {
        event.preventDefault();
        button.setPointerCapture?.(event.pointerId);
        fireGameKey(iframe, key, "keydown");
      };

      const release = (event) => {
        event.preventDefault();
        fireGameKey(iframe, key, "keyup");
      };

      button.addEventListener("pointerdown", press);
      button.addEventListener("pointerup", release);
      button.addEventListener("pointercancel", release);
      button.addEventListener("pointerleave", release);
    });
  });

  document.querySelectorAll("[data-source-card]").forEach((card) => {
    card.addEventListener("toggle", async () => {
      if (!card.open || card.dataset.loaded === "true") return;
      const code = card.querySelector("[data-source-code]");
      code.textContent = "Loading source...";
      try {
        const response = await fetch(card.dataset.sourceUrl);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        code.textContent = await response.text();
        card.dataset.loaded = "true";
      } catch (error) {
        console.error(error);
        code.textContent = "Source file could not be loaded.";
      }
    });
  });
</script>
