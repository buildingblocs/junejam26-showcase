---
import Layout from "../layouts/Layout.astro";
import GameCard from "../components/GameCard.astro";
import { rankedGames, specialGames } from "../data/games";
import { withBase } from "../utils/paths";
---

<Layout title="June Jam Game Showcase" description="BuildingBloCS June Jam 2026 winners and special prize showcase.">
  <main class="container">
    <section class="hero">
      <div>
        <p class="eyebrow">BuildingBloCS June Jam 2026</p>
        <h1>Winner's Showcase</h1>
        <div class="hero-actions">
          <a class="button primary" href="#winners">Browse winners</a>
          <a class="button" href="#specials">Special prizes</a>
        </div>
      </div>
    </section>

    <section id="winners" class="section-block">
      <div class="section-heading">
        <p class="eyebrow">Ranked Awards</p>
        <h2>Main track winners</h2>
      </div>
      <div class="game-grid">
        {rankedGames.map((game) => <GameCard game={game} />)}
      </div>
    </section>

    <section id="specials" class="section-block">
      <div class="section-heading">
        <p class="eyebrow">Special Prizes</p>
        <h2>Special prize winners</h2>
      </div>
      <div class="game-grid">
        {specialGames.map((game) => <GameCard game={game} />)}
      </div>
    </section>

    <section class="view-all">
      <p class="eyebrow">Beyond the winners</p>
      <h2>See what everyone built</h2>
      <p class="lede">
        Browse the full field of June Jam 2026 entries, with slides and source
        for every team.
      </p>
      <a class="button primary" href={withBase("/all-projects/")}>View all projects</a>
    </section>

  </main>
</Layout>
